# ============================================
# GHL API Configuration
# ============================================
# Save this file as ghl.env (remove .template)
# Only 4 fields are required to get started.
# ============================================

# REQUIRED: Your GHL API key
# How to find: GHL > Settings (bottom left gear) > Business Profile > scroll down > "API Key" section > copy it
GHL_API_KEY=your_api_key_here

# REQUIRED: Your GHL Location ID
# How to find: Look at your GHL URL bar. It looks like:
#   app.gohighlevel.com/v2/location/XXXXXXXXXXXXXXXX/dashboard
#   Copy the XXXXXXXXXXXXXXXX part
GHL_LOCATION_ID=your_location_id_here

# OPTIONAL (for now): Your default pipeline ID
# How to find: Ask Claude Code "show me my GHL pipelines" after setup, then paste the ID here
GHL_PIPELINE_ID=

# Don't change these unless GHL tells you to
GHL_BASE_URL=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28

# OPTIONAL: Your timezone (used for calendar queries)
# Examples: America/New_York, America/Los_Angeles, Europe/London, Australia/Brisbane
GHL_TIMEZONE=America/New_York

# REQUIRED for browser automation (optional if you only use the API)
# These are your GHL login credentials, same ones you use at app.gohighlevel.com
GHL_LOGIN_EMAIL=your_email@example.com
GHL_LOGIN_PASSWORD=your_password_here
